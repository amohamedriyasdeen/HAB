# ─────────────────────────────────────────────
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Replace every <placeholder> with your actual value
#   3. NEVER commit your .env file — it is in .gitignore
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=8000
NODE_ENV=development                        # development | production
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017       # e.g. mongodb+srv://<user>:<password>@cluster.mongodb.net
DATABASE_NAME=myhab

# ── Auth / JWT ────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<your_jwt_secret>
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
SALT_ROUNDS=10

# ── Password Reset ────────────────────────────
RESET_TOKEN_EXPIRE=15                       # in minutes

# ── OAuth ─────────────────────────────────────
# Comma-separated providers e.g. google,facebook
OAUTH_PROVIDERS=google
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ── Storage ───────────────────────────────────
# STORAGE_TYPE=s3                           # s3 | public
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_REGION=<your_aws_region>               # e.g. us-east-1
AWS_BUCKET=<your_s3_bucket_name>
AWS_URL=<your_s3_bucket_public_url>

# ── Mail ──────────────────────────────────────
MAIL_MAILER=smtp                           # smtp | ses | mailgun
MAIL_HOST=<your_mail_host>                 # e.g. smtp.mailgun.org
MAIL_PORT=587                              # 465 (SSL) | 587 (TLS)
MAIL_ENCRYPTION=tls                        # tls | ssl
MAIL_USERNAME=<your_mail_username>
MAIL_PASSWORD=<your_mail_password>
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=HAB
