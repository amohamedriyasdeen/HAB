{
  "name": "HAB",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "front:build": "cd frontend && npm run build && xcopy dist ..\\dist /E /I /Y",
    "move:prodbuild": "sudo rm -rf /var/www/html/* && sudo cp -r dist/* /var/www/html/",
    "seeder": "cd backend && node src/database/migrations/seeder.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "multer": "^2.1.1"
  }
}
