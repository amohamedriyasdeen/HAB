# ─────────────────────────────────────────────
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Replace every <placeholder> with your actual value
#   3. NEVER commit your .env file — it is in .gitignore
#   4. All Vite env vars must be prefixed with VITE_
# ─────────────────────────────────────────────

# ── Server Port (optional) ────────────────────
# VITE_PORT=5173

# ── OAuth ─────────────────────────────────────
# Comma-separated enabled providers e.g. google,facebook
VITE_OAUTH_PROVIDERS=google

# ── Environment ───────────────────────────────
# Uncomment ONE at a time — comment the other
VITE_ENV=development
# VITE_ENV=production

# ── API Base URL ──────────────────────────────
# Active URL is selected in code based on VITE_ENV above
VITE_API_BASE_URL_DEV=http://localhost:8000/api
VITE_API_BASE_URL_PROD=<your_production_api_url>  # e.g. https://api.yourdomain.com/api
